# Copy this file to .env and fill in your values

# API server: run with uvicorn server.api:app --reload --port 8765
# Frontend (Vite) expects the API at this URL by default; override with VITE_API_BASE if needed.
# API_PORT=8765
# VITE_API_BASE=http://localhost:8765

# OpenRouter (LLM) — use OPENROUTER_API_KEY or OPEN_ROUTER_API
OPENROUTER_API_KEY=sk-or-v1-xxxx
# Or: OPEN_ROUTER_API=sk-or-v1-xxxx

# Model on OpenRouter (e.g. openai/gpt-4o-mini, anthropic/claude-3-haiku)
LLM_MODEL=openai/gpt-4o-mini

# Optional: Tavily for web search
TAVILY_API_KEY=tvly-xxxx

# Model on OpenRouter (e.g. openai/gpt-4o-mini, anthropic/claude-3-haiku)
LLM_MODEL=openai/gpt-4o-mini

VECTOR_DB_PATH=./data/chroma_db
EMBEDDING_MODEL=all-MiniLM-L6-v2
TOP_K_RESULTS=10
# HF Token (for embedding model)
HF_TOKEN=
# HUGGING_FACE_HUB_TOKEN=
# HUGGINGFACE_TOKEN
